{{#if list}}
<div class="blog-index">
  <ul>
  {{#each list}}
    <li>
      {{#>link (mask ../current this.href this.title)}}
        <span class="date">{{../bdate}}</span>
        <span class="title">{{{../titleHtml}}}</span>
      {{/link}}
    </li>
  {{/each}}
  </ul>
</div>
{{else}}
{{#if content}}{{{content}}}{{/if}}
{{/if}}